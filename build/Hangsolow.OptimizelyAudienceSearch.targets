<Project>
  <!--
    This targets file is automatically imported by consuming projects via NuGet conventions.
    It copies the Optimizely shell module files into the project's output directory so the
    CMS can serve them at runtime from modules/_protected/Hangsolow.OptimizelyAudienceSearch/.
  -->
  <ItemGroup>
    <None Include="$(MSBuildThisFileDirectory)..\contentFiles\any\any\modules\_protected\Hangsolow.OptimizelyAudienceSearch\**\*"
          Condition="'$(PackageId)' != 'Hangsolow.OptimizelyAudienceSearch'">
      <Link>modules\_protected\Hangsolow.OptimizelyAudienceSearch\%(RecursiveDir)%(Filename)%(Extension)</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
